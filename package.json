{
  "name": "@gnolith/diamond",
  "version": "0.4.1",
  "description": "SPARQL and atomic RDF storage for Cloudflare D1 and embedded SQLite.",
  "author": "Gnolith contributors",
  "keywords": [
    "cloudflare-d1",
    "comunica",
    "embedded-sqlite",
    "rdf",
    "rdfjs",
    "sparql"
  ],
  "type": "module",
  "private": false,
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/gnolith/diamond.git"
  },
  "homepage": "https://github.com/gnolith/diamond#readme",
  "bugs": {
    "url": "https://github.com/gnolith/diamond/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "overrides": {
    "sharp": "0.35.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./endpoint": {
      "types": "./dist/endpoint.d.ts",
      "import": "./dist/endpoint.js"
    },
    "./node-sqlite": {
      "types": "./dist/node-sqlite.d.ts",
      "import": "./dist/node-sqlite.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "migrations",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run example:check && npm run worker:bundle:check && npm run worker:local:test && npm run pack:check && npm run consumer:check && npm run licenses:check && npm run readiness:check",
    "conformance": "npm run build && node scripts/run-conformance.mjs summary",
    "conformance:earl": "npm run build && node scripts/run-conformance.mjs earl",
    "consumer:check": "node scripts/consumer-smoke.mjs",
    "example:check": "tsx scripts/wikibase-example-check.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "licenses:check": "license-checker-rseidelsohn --production --summary --onlyAllow \"MIT;ISC;BSD-2-Clause;Apache-2.0;BSD-3-Clause;BlueOak-1.0.0;FreeBSD;(WTFPL OR MIT);UNLICENSED\"",
    "prepack": "npm run build",
    "readiness:check": "node scripts/readiness-check.mjs",
    "release:check": "node scripts/release-check.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "benchmark": "tsx benchmark/run.ts",
    "benchmark:check": "npm run --silent benchmark > benchmark.json && node scripts/validate-benchmark.mjs benchmark.json",
    "benchmark:storage": "tsx benchmark/storage.ts",
    "benchmark:storage:check": "npm run --silent benchmark:storage > benchmark-storage.json",
    "worker:bundle:check": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "worker:local:test": "node scripts/worker-e2e.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@comunica/query-sparql": "^5.3.0",
    "@rdfjs/types": "^2.0.1",
    "asynciterator": "^3.10.0",
    "rdf-data-factory": "^2.0.2",
    "sparqlalgebrajs": "^5.0.2"
  },
  "devDependencies": {
    "@comunica/query-sparql-rdfjs-lite": "^5.3.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/n3": "^1.26.1",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.2.0",
    "eslint": "^10.7.0",
    "fast-check": "^4.3.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "miniflare": "^4.20260714.0",
    "n3": "^1.26.0",
    "prettier": "^3.9.5",
    "rdf-test-suite": "^2.2.0",
    "streamify-array": "^2.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.112.0"
  },
  "license": "MIT"
}
